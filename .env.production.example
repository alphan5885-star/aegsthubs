# ================================================
# CRYPTO E-COMMERCE PLATFORM - PRODUCTION ENV
# ================================================

# DATABASE CONFIGURATION
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_platform?sslmode=require

# HOT WALLET SECURITY
# Generate WALLET_ENCRYPTION_KEY with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=YOUR_32_BYTE_HEX_KEY_HERE

# ENCRYPTED XPRV KEYS (encrypt using the encrypt function in hotWallet.ts)
# Example encryption script: node scripts/encrypt-xprv.mjs
BTC_XPRV=ENCRYPTED_BTC_XPRV_HERE
LTC_XPRV=ENCRYPTED_LTC_XPRV_HERE

# COLD WALLET XPUB KEYS (for deposit address generation)
BTC_XPUB=xpub6CUGRUonZSQ4TWtTMmzXdrXDtypWKiKrhko4egpiMZptKF1E1jA79TjGDBa7vPzM7wAMbYh3VbH1Yp97D5N4U3CXYA5T6A8e4hAuvg5k
LTC_XPUB=Ltub2YKtNfQ1Dpsv6Jb2V8nFExNqXZu4qN2UHEwXnQZV2FqZ2B2M6hPjMh7sHqQ1sQYyD5jY6sKxX2zQ1yP9GZq4H7yW2uP9mJ7Q1sKxX2zQ1y

# MONERO (XMR) WALLET RPC
# For setup details, see XMR_SETUP_GUIDE.md
XMR_WALLET_RPC=http://127.0.0.1:18082
XMR_NETWORK=testnet

# WITHDRAWAL LIMITS
MAX_DAILY_WITHDRAWAL_BTC=1
MAX_DAILY_WITHDRAWAL_LTC=100
MAX_DAILY_WITHDRAWAL_XMR=10
MAX_TX_WITHDRAWAL_BTC=0.1
MAX_TX_WITHDRAWAL_LTC=10
MAX_TX_WITHDRAWAL_XMR=1

# TELEGRAM ALERTS (OPTIONAL)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# NODE ENVIRONMENT
NODE_ENV=production
